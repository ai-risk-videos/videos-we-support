# Backend (backend/main.py) environment variables.
# Copy to a local .env for development, or set these in your Railway service.
# NEVER commit a real .env. The .gitignore already excludes it.

# Required. Anthropic API key. The anthropic SDK reads this automatically.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Optional. Comma-separated Google / YouTube Data API keys, used for channel
# metadata. If unset, the backend falls back to yt-dlp.
GOOGLE_API_KEYS=

# Optional. Webshare rotating residential proxy, used to fetch YouTube
# transcripts from a datacenter host (Railway). Without these, transcript
# fetching is limited to channels that were preloaded into transcripts.json.
WEBSHARE_USER=
WEBSHARE_PASS=

# Optional. Max requests per minute per IP. Default 90.
RATE_LIMIT=90

# Optional. Gate key and file path for the lightweight events log.
EVENTS_KEY=
EVENTS_PATH=
